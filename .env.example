# Optional: after each admission form submit, notify the academy (see api/admission-notify.js).
# Deploy on Vercel and set these in Project → Settings → Environment Variables.
# Local: run `vercel dev` so /api/admission-notify exists; plain `vite` will skip notify (404 is ignored).

# WhatsApp via CallMeBot (https://www.callmebot.com/blog/free-api-whatsapp-messages/)
# CALLMEBOT_APIKEY=
# CALLMEBOT_PHONE=919441896898

# SMS via Twilio (https://www.twilio.com/docs/sms)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SMS_FROM=+1xxxxxxxxxx
# TWILIO_NOTIFY_SMS_TO=+919441896898

# Or POST a copy of the payload to Make / Zapier / n8n:
# ADMISSION_NOTIFY_WEBHOOK_URL=https://hook.us1.make.com/xxxxxxxx
